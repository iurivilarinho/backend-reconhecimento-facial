{"openapi":"3.0.1","info":{"title":"API de Reconhecimento Facial","description":"Reconhecimento facial com ArcFace (InsightFace) via ONNX Runtime: uma foto por usuário, sem treino. Detecção e alinhamento com o detector YuNet do OpenCV.","version":"1"},"servers":[{"url":"http://localhost:8080","description":"Generated server url"}],"paths":{"/users":{"get":{"tags":["user-controller"],"summary":"Listar usuários","description":"Lista todos os usuários cadastrados.","operationId":"findAll","responses":{"200":{"description":"Lista de usuários","content":{"*/*":{"schema":{"type":"array","items":{"$ref":"#/components/schemas/UserResponse"}}}}}}},"post":{"tags":["user-controller"],"summary":"Criar usuário","description":"Cria um usuário sem biometria. Cadastre a biometria depois em /face.","operationId":"create","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/UserRequest"}}},"required":true},"responses":{"201":{"description":"Usuário criado","content":{"*/*":{"schema":{"$ref":"#/components/schemas/UserResponse"}}}},"400":{"description":"Dados inválidos","content":{"*/*":{"schema":{"$ref":"#/components/schemas/UserResponse"}}}}}}},"/face/{userId}/biometrics":{"post":{"tags":["face-recognition-controller"],"summary":"Cadastrar biometria","description":"Gera e salva o embedding facial do usuário a partir de UMA foto.","operationId":"enroll","parameters":[{"name":"userId","in":"path","required":true,"schema":{"type":"integer","format":"int64"}}],"requestBody":{"content":{"multipart/form-data":{"schema":{"required":["file"],"type":"object","properties":{"file":{"type":"string","format":"binary"}}}}}},"responses":{"404":{"description":"Usuário não encontrado","content":{"*/*":{"schema":{"$ref":"#/components/schemas/UserResponse"}}}},"200":{"description":"Biometria cadastrada","content":{"*/*":{"schema":{"$ref":"#/components/schemas/UserResponse"}}}},"400":{"description":"Imagem ausente ou nenhum rosto detectado","content":{"*/*":{"schema":{"$r